# Base44 backend function URL (for snapshot save/load and findings storage)
BASE44_FUNCTION_URL=https://api.base44.com/api/apps/YOUR_APP_ID/functions/leaksbotHandler

# Discord webhook URLs (comma separated)
DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/...

# Discord bot public key (for slash command signature verification)
DISCORD_PUBLIC_KEY=your_discord_app_public_key
